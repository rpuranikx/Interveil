{
  "name": "interveil",
  "version": "0.1.0",
  "description": "Language-agnostic AI agent observability server — trace, inspect, and control any agent in real time",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "interveil": "dist/cli.js"
  },
  "files": [
    "dist/",
    "config/",
    "python/",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run build:server && pnpm run build:ui",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "cd src/ui && vite build --outDir ../../dist/ui",
    "dev": "ts-node src/cli.ts serve",
    "dev:ui": "cd src/ui && vite",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "observability",
    "tracing",
    "llm",
    "debug"
  ],
  "author": "Interveil",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "open": "^9.1.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "yaml": "^2.4.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "@types/bcryptjs": "^2.4.6"
  }
}
